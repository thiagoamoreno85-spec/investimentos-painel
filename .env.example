# === Banco de Dados ===
DATABASE_URL=mysql://user:password@localhost:3306/investimentos

# === Autenticação OAuth ===
VITE_OAUTH_PORTAL_URL=https://your-oauth-provider.com
VITE_APP_ID=your-app-id
JWT_SECRET=your-jwt-secret-min-32-chars
OAUTH_SERVER_URL=https://your-oauth-server.com
OWNER_OPEN_ID=your-owner-open-id
OWNER_NAME=Your Name

# === IA (LLM integrado) ===
BUILT_IN_FORGE_API_URL=https://api.example.com
BUILT_IN_FORGE_API_KEY=your-api-key
VITE_FRONTEND_FORGE_API_KEY=your-frontend-api-key
VITE_FRONTEND_FORGE_API_URL=https://api.example.com

# === Analytics ===
VITE_ANALYTICS_ENDPOINT=https://analytics.example.com
VITE_ANALYTICS_WEBSITE_ID=your-website-id

# === App ===
VITE_APP_TITLE=ManusInvest
VITE_APP_LOGO=https://example.com/logo.png

# === Servidor ===
NODE_ENV=development
PORT=3000
